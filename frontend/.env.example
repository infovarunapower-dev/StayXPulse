# ── StayXPulse frontend environment ──────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored.

# Backend API origin — REQUIRED for the Android build, so the packaged app calls
# your DEPLOYED backend (both web + Android then share one Supabase database).
# Leave UNSET for the web build (it uses same-origin /api automatically).
REACT_APP_API_URL=https://your-stayxpulse-domain.vercel.app

# Public web URL that room QR codes point to (the guest landing page host).
REACT_APP_CLIENT_URL=https://your-stayxpulse-domain.vercel.app
