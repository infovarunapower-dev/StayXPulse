{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/static/(.*)", "dest": "/frontend/static/$1" },
    {
      "comment": "Email clients cannot read bundled /static assets by hash, so the logo needs a stable public URL. Must sit BEFORE the SPA catch-all or it gets swallowed.",
      "src": "/logo.png",
      "dest": "/frontend/logo.png",
      "headers": { "Content-Type": "image/png", "Cache-Control": "public, max-age=86400" }
    },
    {
      "src": "/stayxpulse.apk",
      "dest": "/frontend/stayxpulse.apk",
      "headers": { "Content-Type": "application/vnd.android.package-archive", "Content-Disposition": "attachment; filename=\"StayXPulse.apk\"" }
    },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
