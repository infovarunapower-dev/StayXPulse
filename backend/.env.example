# ── StayXPulse backend environment ───────────────────────────────────────────
# Copy to `.env` for local dev. In production these live in Vercel:
# Project → Settings → Environment Variables. `.env` is gitignored.
#
# Changing a variable in Vercel requires a REDEPLOY before it takes effect.

# ── Database (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — bypasses RLS. NEVER expose this to the browser.
SUPABASE_SERVICE_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE=7d
JWT_REMEMBER_EXPIRE=30d

# ── App URLs ─────────────────────────────────────────────────────────────────
# Used in password-reset links and QR codes, and as the CORS allowlist entry.
CLIENT_URL=https://stayxpulse.sunver.in

# ── Email ────────────────────────────────────────────────────────────────────
# Provider is auto-detected: BREVO_API_KEY present → Brevo HTTP API,
# otherwise SMTP. EMAIL_PROVIDER=brevo|smtp forces one explicitly.
#
# When true, emails are logged to the console and NOT sent. Registration
# treats this as "not delivered" and shows credentials on screen instead.
EMAIL_TEST_MODE=false

# -- Option A: Brevo via SMTP relay (uses the SMTP vars below) --
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=xxxxxxx@smtp-brevo.com
SMTP_PASS=                       # Brevo SMTP key (xsmtpsib-...)

# -- Option B: Brevo via HTTP API (leave SMTP vars unset) --
# BREVO_API_KEY=                 # Brevo API key (xkeysib-...)

# Must be a VERIFIED SENDER in Brevo or every send is rejected.
FROM_EMAIL=stayxpulse@sunver.in
FROM_NAME=StayXPulse

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ⚠️ DEFAULTS TO TRUE IF UNSET. While true, /api/payments/test-pay grants a
# real subscription with no payment — any registered hotel can self-activate
# for free. Set to false the moment Razorpay goes live.
PAYMENT_TEST_MODE=true

# ── AI menu-card scan (Anthropic) ────────────────────────────────────────────
# Without this, POST /hotel/food/scan-menu returns 503.
ANTHROPIC_API_KEY=

# ── Master admin portal ──────────────────────────────────────────────────────
# Shared secret for the read-only /api/master/* endpoints.
MASTER_API_KEY=

# ── Superadmin seed (used by a one-off script, not at runtime) ───────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=
